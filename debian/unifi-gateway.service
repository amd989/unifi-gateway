[Unit]
Description=UniFi Gateway Emulator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/unifi-gateway run
Restart=on-failure
RestartSec=10
Environment=UNIFI_GW_LOG_LEVEL=INFO
Environment=UNIFI_GW_CONFIG=/etc/unifi-gateway/unifi-gateway.conf

[Install]
WantedBy=multi-user.target
