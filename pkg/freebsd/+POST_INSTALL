#!/bin/sh
echo "Enabling unifi_gateway service..."
sysrc unifi_gateway_enable=YES 2>/dev/null || true
echo ""
echo "=== UniFi Gateway installed ==="
echo "  Config: /usr/local/etc/unifi-gateway/unifi-gateway.conf"
